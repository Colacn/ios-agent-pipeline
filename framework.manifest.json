{
  "name": "agent-pipeline",
  "version": "0.6.1",
  "description": "Document-driven agent pipeline for software R&D: analyze → plan → review → develop → test. Each skill is self-contained per Agent Skills spec (SKILL.md + references/ + scripts/ + assets/).",
  "license": "MIT",
  "components": {
    "skills": "skills",
    "agents": "agents",
    "references": "references",
    "scripts": "scripts",
    "templates": "templates"
  },
  "pipeline": ["analyze", "plan", "review", "develop", "test"],
  "outputs": {
    "analyze": "runs/<slug>/outputs/analyze.requirements.md",
    "plan": "runs/<slug>/outputs/plan.solution.md",
    "review": "runs/<slug>/outputs/review.gate.md",
    "develop": "runs/<slug>/outputs/developer.implementation.md",
    "test": ["runs/<slug>/outputs/test.report.md", "runs/<slug>/outputs/test.ledger.md"]
  },
  "skillLayout": {
    "standard": "agentskills.io",
    "selfContained": true,
    "perSkill": ["SKILL.md", "references/", "scripts/", "assets/"],
    "syncScript": "scripts/sync-skill-vendor.sh"
  },
  "installTargets": {
    "cursor": {
      "projectDir": ".cursor",
      "projectGuide": "AGENTS.md",
      "skillDir": ".cursor/skills",
      "notes": "npx skills add Colacn/agent-pipeline@analyze -a cursor -y"
    },
    "claude-code": {
      "projectDir": ".claude",
      "projectGuide": "CLAUDE.md",
      "globalSkillsDir": "~/.claude/skills",
      "notes": "npx skills add … -a claude-code -g -y"
    },
    "codex": {
      "projectDir": ".codex/agent-workflow",
      "projectGuide": "AGENTS.md",
      "globalSkillsDir": "${CODEX_HOME:-~/.codex}/skills",
      "notes": "Global skill discovery; project bundle holds agents + install scripts"
    },
    "neutral": {
      "projectDir": "agent-workflow",
      "projectGuide": "AGENTS.md",
      "notes": "Portable layout for git clone / skills.sh"
    }
  },
  "skillInstall": {
    "agentMap": {
      "analyze": "analyst",
      "plan": "planner",
      "review": "reviewer",
      "develop": "developer",
      "test": "tester"
    },
    "projectExtras": ["scripts/install-framework-to-project.sh", "scripts/install-skill.sh", "scripts/smoke-test.sh"],
    "optionalAgents": {
      "flag": "--with-agents",
      "dir": "agents",
      "notes": "Cursor Subagent thin routing; not part of Agent Skills spec"
    },
    "legacyBundle": {
      "optionalFlag": "--with-legacy-bundle",
      "components": ["references", "scripts", "templates"],
      "notes": "旧版根级 references/scripts/templates；默认不再安装"
    },
    "scripts": {
      "installSkill": "scripts/install-skill.sh",
      "installBundle": "scripts/install-framework-to-project.sh",
      "syncVendor": "scripts/sync-skill-vendor.sh"
    }
  },
  "distribution": {
    "skillsSh": "https://skills.sh/Colacn/agent-pipeline",
    "skillsCli": "npx skills add Colacn/agent-pipeline@analyze",
    "cursorMarketplace": "https://cursor.com/marketplace/publish",
    "exportScript": "scripts/export-distribution-layout.sh",
    "installScript": "scripts/install-framework-to-project.sh",
    "installSkillScript": "scripts/install-skill.sh"
  }
}
